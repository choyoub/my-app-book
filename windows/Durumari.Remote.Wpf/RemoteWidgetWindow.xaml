<Window x:Class="Durumari.Remote.Wpf.RemoteWidgetWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="두루마리 리모콘 위젯" AllowsTransparency="True" Background="Transparent" WindowStyle="None"
        ResizeMode="NoResize" ShowInTaskbar="False" Topmost="True"
        SizeToContent="WidthAndHeight" WindowStartupLocation="Manual"
        PreviewKeyDown="RemoteWidgetWindow_PreviewKeyDown">
    <Window.Resources>
        <SolidColorBrush x:Key="KeycapHighlightBrush" Color="#35FFFFFF"/>
        <Style x:Key="KeycapStyle" TargetType="Button">
            <Setter Property="Width" Value="64"/>
            <Setter Property="Height" Value="64"/>
            <Setter Property="Foreground" Value="#F5F5F5"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Background" Value="#2B4257"/>
            <Setter Property="BorderBrush" Value="#4A637B"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Border x:Name="Keycap" CornerRadius="14" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}">
                                <Border.Effect><DropShadowEffect Color="#AA000000" BlurRadius="10" ShadowDepth="6" Opacity="0.65"/></Border.Effect>
                                <Grid>
                                    <Border CornerRadius="13"
                                            Margin="1"
                                            BorderBrush="{DynamicResource KeycapHighlightBrush}"
                                            BorderThickness="1,1,0,0"
                                            IsHitTestVisible="False"/>
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Keycap" Property="RenderTransform"><Setter.Value><TranslateTransform Y="5"/></Setter.Value></Setter>
                                <Setter TargetName="Keycap" Property="Effect"><Setter.Value><DropShadowEffect Color="#AA000000" BlurRadius="4" ShadowDepth="1" Opacity="0.55"/></Setter.Value></Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid x:Name="RootScale" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="18"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <TextBlock x:Name="DragLabel" Grid.Row="0" Text="DRAG"
                   FontFamily="Segoe UI" FontSize="8" FontWeight="Bold"
                   Foreground="#A3A3A3" Visibility="Collapsed"
                   HorizontalAlignment="Center" VerticalAlignment="Center"
                   Panel.ZIndex="2"/>
        <StackPanel x:Name="KeycapPanel" Grid.Row="1" Orientation="Horizontal" Margin="8,0,8,8" Background="Transparent">
            <Button x:Name="LeftKeycap" Style="{StaticResource KeycapStyle}" PreviewMouseLeftButtonDown="Keycap_PreviewMouseLeftButtonDown" Click="Left_Click">
                <StackPanel VerticalAlignment="Center">
                    <Viewbox x:Name="LeftArrow" Width="24" Height="24" HorizontalAlignment="Center">
                        <Path Width="24" Height="24"
                              Data="M 20,12 L 6,12 M 6,12 L 12,6 M 6,12 L 12,18"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"/>
                    </Viewbox>
                    <TextBlock x:Name="LeftLabel" Text="LEFT" FontSize="8" Opacity="0.55" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
            <Grid x:Name="KeycapGap" Width="14" Background="Transparent"
                  Cursor="Hand"
                  MouseEnter="DragHandleArea_MouseEnter"
                  MouseLeave="DragHandleArea_MouseLeave"
                  MouseLeftButtonDown="DragHandleArea_MouseLeftButtonDown">
                <Border x:Name="DragHandle" Width="4" Height="10" CornerRadius="2"
                        Background="#666666" Opacity="0.36"
                        HorizontalAlignment="Center" VerticalAlignment="Center"
                        Margin="0"/>
            </Grid>
            <Button x:Name="RightKeycap" Style="{StaticResource KeycapStyle}" PreviewMouseLeftButtonDown="Keycap_PreviewMouseLeftButtonDown" Click="Right_Click">
                <StackPanel VerticalAlignment="Center">
                    <Viewbox x:Name="RightArrow" Width="24" Height="24" HorizontalAlignment="Center">
                        <Path Width="24" Height="24"
                              Data="M 4,12 L 18,12 M 18,12 L 12,6 M 18,12 L 12,18"
                              Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                              StrokeThickness="2.5"
                              StrokeStartLineCap="Round"
                              StrokeEndLineCap="Round"
                              StrokeLineJoin="Round"/>
                    </Viewbox>
                    <TextBlock x:Name="RightLabel" Text="RIGHT" FontSize="8" Opacity="0.55" HorizontalAlignment="Center" Margin="0,2,0,0"/>
                </StackPanel>
            </Button>
        </StackPanel>
        <Canvas x:Name="KeycapEffects" Grid.RowSpan="2" Panel.ZIndex="10" IsHitTestVisible="False" ClipToBounds="False"/>
    </Grid>
</Window>
