<Window x:Class="Durumari.Remote.Wpf.MainWindow" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" Title="두루마리 Windows 리모콘" Icon="Assets/durumari.ico" Width="480" Height="780" MinHeight="780" WindowStyle="None" ResizeMode="CanResize" AllowsTransparency="True" Background="Transparent" WindowStartupLocation="CenterScreen">
  <Window.Resources>
    <SolidColorBrush x:Key="Mica" Color="#202020"/><SolidColorBrush x:Key="Titlebar" Color="#CC1C1C1C"/><SolidColorBrush x:Key="Card" Color="#2D2D2D"/><SolidColorBrush x:Key="Input" Color="#323232"/><SolidColorBrush x:Key="FocusedInput" Color="#3D3D3D"/><SolidColorBrush x:Key="Text" Color="#F5F5F5"/><SolidColorBrush x:Key="Muted" Color="#A3A3A3"/><SolidColorBrush x:Key="Border" Color="#14FFFFFF"/><SolidColorBrush x:Key="Accent" Color="#0078D4"/><SolidColorBrush x:Key="AccentSubtle" Color="#400078D4"/><SolidColorBrush x:Key="PortInput" Color="#80323232"/><SolidColorBrush x:Key="PortText" Color="#FF737373"/><SolidColorBrush x:Key="PortBorder" Color="#14FFFFFF"/><SolidColorBrush x:Key="SliderTrack" Color="#444444"/><SolidColorBrush x:Key="SliderThumbStroke" Color="#FF1C1C1C"/><SolidColorBrush x:Key="TitleMuted" Color="#FFA3A3A3"/><SolidColorBrush x:Key="CaptionText" Color="#FFF5F5F5"/>
    <Style x:Key="CardStyle" TargetType="Border"><Setter Property="Background" Value="{DynamicResource Card}"/><Setter Property="BorderBrush" Value="{DynamicResource Border}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="CornerRadius" Value="8"/><Setter Property="Padding" Value="20"/><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="BorderBrush" Value="{DynamicResource AccentSubtle}"/></Trigger></Style.Triggers></Style>
    <Style x:Key="LabelStyle" TargetType="TextBlock"><Setter Property="Foreground" Value="{DynamicResource Text}"/><Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic"/></Style>
    <Style x:Key="InlineIconStyle" TargetType="TextBlock"><Setter Property="FontFamily" Value="Segoe Fluent Icons"/><Setter Property="Foreground" Value="{DynamicResource Accent}"/><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Height" Value="20"/><Setter Property="LineHeight" Value="20"/><Setter Property="LineStackingStrategy" Value="BlockLineHeight"/><Setter Property="TextAlignment" Value="Center"/><Setter Property="RenderTransform"><Setter.Value><TranslateTransform Y="-2"/></Setter.Value></Setter></Style>
    <Style x:Key="InlineTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource LabelStyle}"><Setter Property="VerticalAlignment" Value="Center"/><Setter Property="Height" Value="20"/><Setter Property="LineHeight" Value="20"/><Setter Property="LineStackingStrategy" Value="BlockLineHeight"/></Style>
    <Style x:Key="InputStyle" TargetType="TextBox"><Setter Property="Height" Value="36"/><Setter Property="Padding" Value="12,8"/><Setter Property="Background" Value="Transparent"/><Setter Property="Foreground" Value="{DynamicResource Text}"/><Setter Property="BorderThickness" Value="0"/><Setter Property="FontSize" Value="14"/></Style>
    <Style x:Key="DomainInputFrame" TargetType="Border"><Setter Property="Height" Value="38"/><Setter Property="CornerRadius" Value="4"/><Setter Property="Background" Value="{DynamicResource Input}"/><Setter Property="BorderBrush" Value="#99606060"/><Setter Property="BorderThickness" Value="0,0,0,2"/><Style.Triggers><Trigger Property="IsKeyboardFocusWithin" Value="True"><Setter Property="Background" Value="{DynamicResource FocusedInput}"/><Setter Property="BorderBrush" Value="{DynamicResource Accent}"/></Trigger></Style.Triggers></Style>
    <Style x:Key="PortInputStyle" TargetType="TextBox"><Setter Property="Width" Value="96"/><Setter Property="Height" Value="30"/><Setter Property="Padding" Value="8,5"/><Setter Property="Background" Value="{DynamicResource PortInput}"/><Setter Property="Foreground" Value="{DynamicResource PortText}"/><Setter Property="BorderBrush" Value="{DynamicResource PortBorder}"/><Setter Property="BorderThickness" Value="1"/><Setter Property="FontSize" Value="14"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="TextAlignment" Value="Center"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="Opacity" Value="0.60"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="TextBox"><Border CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}"><ScrollViewer x:Name="PART_ContentHost"/></Border></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="ActionStyle" TargetType="Button"><Setter Property="Foreground" Value="White"/><Setter Property="Background" Value="{DynamicResource Accent}"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Padding" Value="0"/><Setter Property="Height" Value="32"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border CornerRadius="4" Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="FluentSwitch" TargetType="ToggleButton"><Setter Property="Width" Value="38"/><Setter Property="Height" Value="20"/><Setter Property="Background" Value="#444444"/><Setter Property="BorderBrush" Value="#555555"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ToggleButton"><Border x:Name="Track" CornerRadius="10" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1.5"><Ellipse x:Name="Thumb" Width="12" Height="12" Fill="#A3A3A3" HorizontalAlignment="Left" Margin="3,0,0,0"/></Border><ControlTemplate.Triggers><Trigger Property="IsChecked" Value="True"><Setter TargetName="Track" Property="Background" Value="{DynamicResource Accent}"/><Setter TargetName="Track" Property="BorderBrush" Value="Transparent"/><Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right"/><Setter TargetName="Thumb" Property="Margin" Value="0,0,3,0"/><Setter TargetName="Thumb" Property="Fill" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="DarkComboItem" TargetType="ComboBoxItem"><Setter Property="Height" Value="30"/><Setter Property="Padding" Value="12,0"/><Setter Property="Foreground" Value="{DynamicResource Text}"/><Setter Property="Background" Value="Transparent"/><Setter Property="FontSize" Value="12"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="HorizontalContentAlignment" Value="Left"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBoxItem"><Border x:Name="ItemBorder" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}"><ContentPresenter VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsHighlighted" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="#264C4C4C"/></Trigger><Trigger Property="IsSelected" Value="True"><Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource Accent}"/><Setter Property="Foreground" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="WidgetSizeOption" TargetType="RadioButton"><Setter Property="Height" Value="28"/><Setter Property="Foreground" Value="{DynamicResource Muted}"/><Setter Property="FontSize" Value="11"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="HorizontalContentAlignment" Value="Center"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="RadioButton"><Border x:Name="OptionBackground" Background="Transparent" CornerRadius="3"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="OptionBackground" Property="Background" Value="#174C4C4C"/></Trigger><Trigger Property="IsChecked" Value="True"><Setter TargetName="OptionBackground" Property="Background" Value="{DynamicResource Accent}"/><Setter Property="Foreground" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="FeedbackCheckBox" TargetType="CheckBox"><Setter Property="Foreground" Value="{DynamicResource Text}"/><Setter Property="FontFamily" Value="Segoe UI, Malgun Gothic"/><Setter Property="FontSize" Value="12"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="Cursor" Value="Hand"/><Setter Property="VerticalContentAlignment" Value="Center"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="CheckBox"><StackPanel Orientation="Horizontal"><Border x:Name="CheckBoxBorder" Width="16" Height="16" CornerRadius="3" Background="{DynamicResource Input}" BorderBrush="{DynamicResource Border}" BorderThickness="1"><Path x:Name="CheckMark" Data="M 3,8 L 7,12 L 13,4" Stroke="White" StrokeThickness="2" StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Visibility="Collapsed"/></Border><ContentPresenter Margin="7,0,0,0" VerticalAlignment="Center"/></StackPanel><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource Accent}"/></Trigger><Trigger Property="IsChecked" Value="True"><Setter TargetName="CheckBoxBorder" Property="Background" Value="{DynamicResource Accent}"/><Setter TargetName="CheckBoxBorder" Property="BorderBrush" Value="{DynamicResource Accent}"/><Setter TargetName="CheckMark" Property="Visibility" Value="Visible"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="DarkCombo" TargetType="ComboBox"><Setter Property="Height" Value="30"/><Setter Property="Background" Value="{DynamicResource Input}"/><Setter Property="Foreground" Value="{DynamicResource Text}"/><Setter Property="BorderBrush" Value="{DynamicResource Border}"/><Setter Property="FontSize" Value="12"/><Setter Property="FontWeight" Value="SemiBold"/><Setter Property="ItemContainerStyle" Value="{StaticResource DarkComboItem}"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="ComboBox"><Grid><Border CornerRadius="4" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" Padding="12,0,10,0"><Grid><ContentPresenter Content="{TemplateBinding SelectionBoxItem}" VerticalAlignment="Center"/><TextBlock Text="&#xE70D;" FontFamily="Segoe Fluent Icons" Foreground="{DynamicResource Muted}" HorizontalAlignment="Right" VerticalAlignment="Center" FontSize="10"/></Grid></Border><ToggleButton x:Name="DropDownToggle" Background="Transparent" BorderThickness="0" Focusable="False" IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"><ToggleButton.Template><ControlTemplate TargetType="ToggleButton"><Border Background="Transparent"/></ControlTemplate></ToggleButton.Template></ToggleButton><Popup IsOpen="{TemplateBinding IsDropDownOpen}" Placement="Bottom" PlacementTarget="{Binding ElementName=DropDownToggle}" AllowsTransparency="True" PopupAnimation="Fade"><Border Margin="0,2,0,0" Background="{DynamicResource Input}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="4" MinWidth="{Binding ActualWidth, ElementName=DropDownToggle}"><ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto"><ItemsPresenter/></ScrollViewer></Border></Popup></Grid></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="SliderTrackZone" TargetType="RepeatButton"><Setter Property="Focusable" Value="False"/><Setter Property="IsTabStop" Value="False"/><Setter Property="IsHitTestVisible" Value="False"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="RepeatButton"><Border Background="Transparent"/></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="FluentSlider" TargetType="Slider"><Setter Property="Focusable" Value="False"/><Setter Property="IsMoveToPointEnabled" Value="False"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Slider"><Grid VerticalAlignment="Center"><Border Height="4" CornerRadius="2" Background="{DynamicResource SliderTrack}"/><Track x:Name="PART_Track"><Track.DecreaseRepeatButton><RepeatButton Style="{StaticResource SliderTrackZone}" Command="Slider.DecreaseLarge"/></Track.DecreaseRepeatButton><Track.Thumb><Thumb Width="16" Height="16"><Thumb.Template><ControlTemplate TargetType="Thumb"><Ellipse Fill="{DynamicResource Accent}" Stroke="{DynamicResource SliderThumbStroke}" StrokeThickness="3"/></ControlTemplate></Thumb.Template></Thumb></Track.Thumb><Track.IncreaseRepeatButton><RepeatButton Style="{StaticResource SliderTrackZone}" Command="Slider.IncreaseLarge"/></Track.IncreaseRepeatButton></Track></Grid></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="CaptionButton" TargetType="Button"><Setter Property="Width" Value="44"/><Setter Property="Height" Value="48"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Foreground" Value="{DynamicResource CaptionText}"/><Setter Property="FontFamily" Value="Segoe Fluent Icons"/><Setter Property="FontSize" Value="11"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="CaptionBackground" Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="CaptionBackground" Property="Background" Value="#18000000"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
    <Style x:Key="CloseCaptionButton" TargetType="Button"><Setter Property="Width" Value="44"/><Setter Property="Height" Value="48"/><Setter Property="Background" Value="Transparent"/><Setter Property="BorderThickness" Value="0"/><Setter Property="Foreground" Value="{DynamicResource CaptionText}"/><Setter Property="FontFamily" Value="Segoe Fluent Icons"/><Setter Property="FontSize" Value="11"/><Setter Property="Template"><Setter.Value><ControlTemplate TargetType="Button"><Border x:Name="CloseBackground" Background="{TemplateBinding Background}"><ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/></Border><ControlTemplate.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter TargetName="CloseBackground" Property="Background" Value="#C42B1C"/><Setter Property="Foreground" Value="White"/></Trigger></ControlTemplate.Triggers></ControlTemplate></Setter.Value></Setter></Style>
  </Window.Resources>
  <Border Background="{DynamicResource Mica}" BorderBrush="#20FFFFFF" BorderThickness="1" CornerRadius="0">
    <Grid>
      <Grid.RowDefinitions><RowDefinition Height="48"/><RowDefinition Height="*"/></Grid.RowDefinitions>
      <Grid Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" Background="{DynamicResource Titlebar}"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="88"/></Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" Margin="16,0" VerticalAlignment="Center"><Image Source="Assets/durumari-icon.png" Width="20" Height="20" VerticalAlignment="Center"/><TextBlock Style="{StaticResource LabelStyle}" Text="두루마리 Windows 리모콘" FontSize="12" FontWeight="SemiBold" Foreground="{DynamicResource TitleMuted}" Margin="10,0,0,0" VerticalAlignment="Center"/></StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right"><Button Style="{StaticResource CaptionButton}" Content="&#xE921;" Click="Minimize_Click"/><Button Style="{StaticResource CloseCaptionButton}" Content="&#xE8BB;" Click="Close_Click"/></StackPanel>
      </Grid>
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Disabled"><StackPanel Margin="24,24,24,8">
        <TextBlock Style="{StaticResource LabelStyle}" Text="두루마리 리모컨" FontSize="30" FontWeight="Bold"/><TextBlock Style="{StaticResource LabelStyle}" Text="Android 페이지를 Windows에서 편안하게 넘겨보세요." Foreground="{DynamicResource Muted}" FontSize="12" FontWeight="SemiBold" Margin="0,6,0,20"/>
        <Border Style="{StaticResource CardStyle}"><StackPanel><StackPanel Orientation="Horizontal" Height="20" VerticalAlignment="Center"><TextBlock Style="{StaticResource InlineIconStyle}" Text="&#xE8EA;" FontSize="15"/><TextBlock Style="{StaticResource InlineTitleStyle}" Text="Android 기기" FontSize="15" FontWeight="Bold" Margin="8,0,0,0"/></StackPanel><TextBlock Style="{StaticResource LabelStyle}" Text="Tailscale 주소와 Android 앱에 설정한 포트를 입력하세요." Foreground="{DynamicResource Muted}" FontSize="12" Margin="0,6,0,24"/>
          <TextBlock Style="{StaticResource LabelStyle}" Text="TAILSCALE 도메인 또는 IP" Foreground="{DynamicResource Muted}" FontSize="10" FontWeight="Bold"/><Border Style="{StaticResource DomainInputFrame}" Margin="0,8,0,16"><TextBox x:Name="HostInput" Style="{StaticResource InputStyle}" LostKeyboardFocus="ConnectionSetting_LostKeyboardFocus"/></Border>
          <TextBlock Style="{StaticResource LabelStyle}" Text="포트 번호" Foreground="{DynamicResource Muted}" FontSize="10" FontWeight="Bold"/><StackPanel Orientation="Horizontal" Margin="0,10,0,16"><ToggleButton x:Name="DefaultPortToggle" Style="{StaticResource FluentSwitch}" IsChecked="True" Checked="DefaultPortToggle_Changed" Unchecked="DefaultPortToggle_Changed"/><TextBlock Style="{StaticResource LabelStyle}" Text="기본 포트 사용 (48484)" FontWeight="Bold" VerticalAlignment="Center" Margin="10,0,20,0"/><TextBox x:Name="PortNumberInput" Style="{StaticResource PortInputStyle}" Text="48484" IsHitTestVisible="False" Focusable="False" Cursor="Arrow" GotKeyboardFocus="PortNumberInput_GotKeyboardFocus" LostKeyboardFocus="PortNumberInput_LostKeyboardFocus"/></StackPanel>
          <Border Height="1" Background="{DynamicResource Border}"/><Grid Margin="0,14,0,0"><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="112"/></Grid.ColumnDefinitions><Border x:Name="ConnectionStatusIndicator" Height="30" Padding="14,0,16,0" CornerRadius="15" Background="{DynamicResource Input}" BorderBrush="{DynamicResource Border}" BorderThickness="1" HorizontalAlignment="Left"><StackPanel Orientation="Horizontal" VerticalAlignment="Center"><Ellipse x:Name="ConnectionStatusDot" Width="10" Height="10" Fill="#737373" Margin="0,0,8,0"/><TextBlock x:Name="ConnectionStatusText" Style="{StaticResource LabelStyle}" Text="연결 안 됨" Foreground="{DynamicResource Muted}" FontSize="12" FontWeight="Bold" VerticalAlignment="Center"/></StackPanel></Border><Button x:Name="ConnectionButton" Grid.Column="1" Style="{StaticResource ActionStyle}" Click="ConnectionButton_Click"><StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center"><Viewbox Width="13" Height="13" Margin="0,0,6,0" Stretch="Uniform"><Canvas Width="14" Height="14"><Path Data="M4,1 H5.5 V5 H8.5 V1 H10 V5 H11 V7 C11,9.2 9.2,11 7,11 C4.8,11 3,9.2 3,7 V5 H4 Z M6.25,11 H7.75 V14 H6.25 Z" Fill="White"/></Canvas></Viewbox><TextBlock x:Name="ConnectionButtonText" Text="연결" VerticalAlignment="Center"/></StackPanel></Button></Grid>
        </StackPanel></Border>
        <Border Style="{StaticResource CardStyle}" Margin="0,20,0,0"><StackPanel><StackPanel Orientation="Horizontal" Height="20" VerticalAlignment="Center"><TextBlock Style="{StaticResource InlineIconStyle}" Text="&#xE713;" FontSize="15"/><TextBlock Style="{StaticResource InlineTitleStyle}" Text="리모콘 위젯 스타일" FontSize="15" FontWeight="Bold" Margin="8,0,0,0"/></StackPanel><TextBlock Style="{StaticResource LabelStyle}" Text="키캡 위젯의 개별 물리 디자인과 반투명도를 커스텀합니다." Foreground="{DynamicResource Muted}" FontSize="12" Margin="0,6,0,20"/><Grid><Grid.ColumnDefinitions><ColumnDefinition Width="136"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="위젯 크기" FontWeight="Bold" VerticalAlignment="Center"/><Border Grid.Column="1" Height="30" Padding="1" Background="{DynamicResource Input}" BorderBrush="{DynamicResource Border}" BorderThickness="1" CornerRadius="4"><Grid><Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions><RadioButton x:Name="SmallWidgetSizeOption" Grid.Column="0" GroupName="WidgetSize" Style="{StaticResource WidgetSizeOption}" Content="작게" Tag="small" Checked="WidgetSizeOption_Checked"/><RadioButton x:Name="NormalWidgetSizeOption" Grid.Column="1" GroupName="WidgetSize" Style="{StaticResource WidgetSizeOption}" Content="보통" Tag="normal" IsChecked="True" Checked="WidgetSizeOption_Checked"/><RadioButton x:Name="LargeWidgetSizeOption" Grid.Column="2" GroupName="WidgetSize" Style="{StaticResource WidgetSizeOption}" Content="크게" Tag="large" Checked="WidgetSizeOption_Checked"/></Grid></Border></Grid><Grid Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="136"/><ColumnDefinition/><ColumnDefinition Width="40"/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="투명도" FontWeight="Bold" VerticalAlignment="Center"/><Slider x:Name="WidgetOpacitySlider" Grid.Column="1" Style="{StaticResource FluentSlider}" Minimum="20" Maximum="100" Value="95" ValueChanged="WidgetOpacitySlider_ValueChanged"/><TextBlock x:Name="WidgetOpacityText" Grid.Column="2" Style="{StaticResource LabelStyle}" Text="95%" Foreground="{DynamicResource Muted}" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Right"/></Grid><Grid Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="136"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="키캡 스타일 테마" FontWeight="Bold" VerticalAlignment="Center"/><ComboBox x:Name="WidgetThemeCombo" Grid.Column="1" Style="{StaticResource DarkCombo}" SelectedIndex="0" SelectionChanged="WidgetThemeCombo_SelectionChanged"><ComboBoxItem Content="윈도우 시스템 동기화" Tag="system"/><ComboBoxItem Content="다크 기계식 키캡" Tag="dark"/><ComboBoxItem Content="라이트 정밀 키캡" Tag="light"/><ComboBoxItem Content="아크릴 투명 글래스" Tag="acrylic"/></ComboBox></Grid><Grid Margin="0,18,0,0"><Grid.ColumnDefinitions><ColumnDefinition Width="136"/><ColumnDefinition/></Grid.ColumnDefinitions><TextBlock Style="{StaticResource LabelStyle}" Text="클릭 피드백" FontWeight="Bold" VerticalAlignment="Center"/><StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center"><CheckBox x:Name="WidgetEffectCheckBox" Style="{StaticResource FeedbackCheckBox}" Content="이펙트" IsChecked="True" Click="WidgetFeedbackOption_Changed"/><CheckBox x:Name="WidgetSoundCheckBox" Style="{StaticResource FeedbackCheckBox}" Content="사운드" IsChecked="True" Margin="24,0,0,0" Click="WidgetFeedbackOption_Changed"/></StackPanel></Grid></StackPanel></Border>
        <StackPanel Orientation="Horizontal" Margin="2,12,0,0"><Border Width="12" Height="12" CornerRadius="6" Background="{DynamicResource Accent}" Margin="0,1,8,0" VerticalAlignment="Top"><TextBlock Text="i" Foreground="White" FontFamily="Segoe UI" FontSize="9" FontWeight="Bold" TextAlignment="Center" VerticalAlignment="Center" LineHeight="12"/></Border><TextBlock Style="{StaticResource LabelStyle}" Text="연결에 성공하면 ← (이전 페이지) | → (다음 페이지) 형태의 초미니 투명 키캡 위젯이 즉시 로드됩니다." Foreground="{DynamicResource Muted}" FontSize="11" TextWrapping="Wrap" Width="390" VerticalAlignment="Top"/></StackPanel>
      </StackPanel></ScrollViewer>
    </Grid>
  </Border>
</Window>
