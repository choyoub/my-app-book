<resources>
    <style name="AppTheme" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowDisablePreview">true</item>
        <item name="android:colorAccent">#9A5A10</item>

        <item name="android:windowSplashScreenBackground">#0D1B2A</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/splash_icon_transparent</item>
        <item name="android:windowSplashScreenIconBackgroundColor">#0D1B2A</item>
        <item name="android:windowSplashScreenAnimationDuration">0</item>
    </style>
</resources>
